<h1>IFatec</h1>

<a href="/Index?escolha=ita">🇮🇹 Menu Italiano</a> |
<a href="/Index?escolha=jap">🇯🇵 Menu Japonês</a>

<hr />

@if (meuCliente != null)
{
    <div style="background-color:#f5f5f5; padding:15px; margin-bottom:15px;">
        <h2> Menu @(escolhaAtual == "ita" ? "Italiano" : "Japonês")</h2>

        <p><strong> Prato Principal:</strong> @meuCliente.BuscarDescricaoPratoPrincipal()</p>
        <p><strong> Sobremesa:</strong> @meuCliente.BuscarDescricaoSobremesa()</p>
        <p><strong> Bebida:</strong> @meuCliente.BuscarDescricaoBebida()</p>
    </div>
}


@if (string.IsNullOrEmpty(escolhaAtual))
{
    <p> Escolha um menu para começar.</p>
}
else
{
    <h2>Monte seu pedido (@(escolhaAtual == "ita" ? "Italiano" : "Japonês"))</h2>

    <form method="post" action="/Index?escolha=@escolhaAtual">

        <h4>Extras:</h4>

        <input type="checkbox" name="addParmesao" value="true" /> Parmesão <br />
        <input type="checkbox" name="addGelo" value="true" /> Gelo <br />
        <input type="checkbox" name="addLimao" value="true" /> Limão <br />
        <input type="checkbox" name="addSorvete" value="true" /> Sorvete <br />

        <br />

        <label>Remover ingrediente:</label><br />
        <input type="text" name="ingrediente" placeholder="Ex: cebola..." />

        <br /><br />

        <button type="submit" name="acao" value="fazer_pedido">Montar Pedido</button>
        <button type="submit" name="acao" value="confirmar_final">Salvar Pedido</button>
        <button type="submit" name="acao" value="undo">Desfazer</button>
    </form>
}

<hr />

@if (meuPedido != null && !string.IsNullOrEmpty(meuPedido.GetPratoPrincipal()))
{
    <h3>Pedido Atual</h3>
    <p><strong>Prato:</strong> @meuPedido.GetPratoPrincipal()</p>
    <p><strong>Sobremesa:</strong> @meuPedido.GetSobremesa()</p>
    <p><strong>Bebida:</strong> @meuPedido.GetBebida()</p>
}

<hr />

<h3>Histórico (Memento)</h3>

@if (meuHistorico != null && meuHistorico.GetHistorico().Count > 0)
{
    <ul>
        @foreach (var item in meuHistorico.GetHistorico())
        {
            <li>
                <strong>@item.GetData().ToString("HH:mm:ss")</strong> -
                @item.GetPratoPrincipal()
                @item.GetBebida()
                @item.GetSobremesa()
            </li>
        }
    </ul>
}
else
{
    <p>Nenhum pedido salvo ainda.</p>
}